# Flask 開發設定
FLASK_ENV=development
FLASK_DEBUG=True
#可以不管 只要加入好友 看是否能收到訊息即可 功能給line組自己測試
# VIP 到店通知用 LINE Bot
# STAFF_LINE_CHANNEL_ACCESS_TOKEN：LINE Bot 的 Channel Access Token
# STAFF_LINE_USER_ID：接收 VIP 通知的店員 LINE User ID，多人請用逗號分隔，例如 U111...,U222...,U333...
STAFF_LINE_CHANNEL_ACCESS_TOKEN=
STAFF_LINE_USER_ID=

# 一般 LINE Bot 設定，未來會員互動功能會用到
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LIFF App ID，註冊頁 register.js 會呼叫 GET /line/config 取得這個值再執行 liff.init()
# 去 LINE Developers Console 的 LIFF 分頁複製 LIFF ID 填入
LIFF_ID=

# 對外正式網址（Cloud Run），LINE 註冊連結會用這個組出 register_url
# 本機開發不用填，沒設定時會自動 fallback 用 request.url_root
# 正式環境（Cloud Run）要設成，結尾不要加 /：
# PUBLIC_BASE_URL=https://smart-member-296909390205.asia-southeast1.run.app
PUBLIC_BASE_URL=

# MySQL 資料庫設定
# 每個人依照自己電腦的 MySQL 設定填寫
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_member_system



# Camera 設定
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30